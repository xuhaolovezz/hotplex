{
  "name": "hotplex-client",
  "version": "1.18.1",
  "description": "TypeScript client SDK for HotPlex Gateway (AEP v1)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["hotplex", "claude-code", "aep", "websocket", "ai-agent"],
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  },
  "dependencies": {
    "ws": "^8.16.0",
    "eventemitter3": "^5.0.1",
    "jose": "^5.2.0"
  },
  "peerDependencies": {
    "ws": "^8.16.0"
  }
}